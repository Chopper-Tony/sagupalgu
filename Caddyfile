{
	# DOMAIN_NAME 미설정(IP 기반 배포) 시 Let's Encrypt 인증서 발급 불가 →
	# auto HTTPS 비활성. 도메인 붙이면 아래 https:// 블록을 활성화.
	auto_https off
}

:80 {
	reverse_proxy /api/* backend:8000
	reverse_proxy /health* backend:8000
	reverse_proxy /uploads/* backend:8000
	reverse_proxy frontend:80
}

# 도메인 연결 후 HTTPS 자동화를 원하면 아래 블록의 주석을 풀고 {$DOMAIN_NAME} 환경변수 설정
