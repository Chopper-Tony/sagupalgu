# ==============================
# Supabase (PostgreSQL + pgvector)
# ==============================
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ==============================
# Security
# ==============================
SECRET_ENCRYPTION_KEY=<generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">

# ==============================
# Vision AI
# ==============================
# Primary provider 선택. 실행 시 1차 실패(키 누락·런타임 에러)하면 자동 fallback.
# - VISION_PROVIDER=gemini (기본) → Gemini 우선, OpenAI fallback
# - VISION_PROVIDER=openai       → OpenAI 우선, Gemini fallback
VISION_PROVIDER=gemini

OPENAI_API_KEY=<your-openai-api-key>
OPENAI_VISION_MODEL=gpt-4.1-mini

GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_VISION_MODEL=gemini-2.5-flash

# ==============================
# Listing generation LLM
# ==============================
# Options: openai | gemini | solar (fallback chain: gemini → openai → solar)
LISTING_LLM_PROVIDER=openai

OPENAI_LISTING_MODEL=gpt-4.1-mini
GEMINI_LISTING_MODEL=gemini-2.5-flash

UPSTAGE_API_KEY=<your-upstage-api-key>
SOLAR_LISTING_MODEL=solar-pro2

# ==============================
# Platform publish accounts
# ==============================
JOONGNA_USERNAME=<your-joongna-email>
JOONGNA_PASSWORD=<your-joongna-password>

BUNJANG_USERNAME=<your-bunjang-email>
BUNJANG_PASSWORD=<your-bunjang-password>

# 당근마켓 (Android 에뮬레이터)
# adb devices 로 확인한 device serial
DAANGN_DEVICE_ID=<your-device-serial>

# ==============================
# Playwright settings
# ==============================
PUBLISH_HEADLESS=true
PUBLISH_SLOW_MO=0

# ==============================
# Job Queue
# ==============================
PUBLISH_USE_QUEUE=true
ADMIN_API_KEY=<your-admin-api-key>
# API 컨테이너: false, Worker 컨테이너: true
RUN_PUBLISH_WORKER=true

# ==============================
# S3 보조 스토리지 (증적 스크린샷)
# ==============================
S3_AUXILIARY_ENABLED=false
S3_AUXILIARY_BUCKET=<your-bucket-name>
S3_AUXILIARY_REGION=ap-northeast-2

# ==============================
# Deployment
# ==============================
# Caddy HTTPS용 도메인 (미설정 시 localhost)
DOMAIN_NAME=localhost
# 환경: local | dev | prod
ENVIRONMENT=local

# ==============================
# CORS
# ==============================
# local/dev: 기본값 http://localhost:3000,http://localhost:5173 (설정 불필요)
# prod: 실제 도메인으로 반드시 설정
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ==============================
# Notifications
# ==============================
DISCORD_WEBHOOK_URL=<your-discord-webhook-url>
