# ==============================
# 프론트엔드 환경변수 (Vite)
# ==============================
# 모든 변수는 VITE_ 접두사 필수. 빌드 시점에 번들에 포함되므로 public 키만 설정.

# 백엔드 API (생략 시 /api/v1 상대 경로 — Caddy 프록시 뒤에서 동작)
VITE_API_URL=/api/v1

# Supabase Auth (프론트엔드 클라이언트용 — anon key 사용)
# Supabase 대시보드 → Project Settings → API 에서 확인
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<supabase-anon-key>
